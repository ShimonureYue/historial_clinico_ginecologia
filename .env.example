# ── Expediente Clinico Ginecologia — Configuracion ───────
# Copia este archivo como ".env" y ajusta los valores.
# NUNCA subas .env a git (ya esta en .gitignore).

# ── Backend ───────────────────────────────────────────────
# Puerto del servidor (default: 8000)
PORT=8000

# Clave secreta para JWT (cambiar en produccion)
SECRET_KEY=expediente-clinico-secret-key-change-in-production

# Horas de vigencia del token JWT (default: 24)
# TOKEN_EXPIRE_HOURS=24

# Ruta a la base de datos SQLite (default: database/expediente_clinico.db)
# DB_PATH=

# ── Frontend (solo desarrollo) ───────────────────────────
VITE_API_PORT=8000

# ── Colposcopias — AWS S3 (opcional) ─────────────────────
# Credenciales IAM para subir/ver imagenes de colposcopia.
# Si no se configura, el sistema funciona sin imagenes S3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
S3_BUCKET_NAME=expediente-clinico

# ── Respaldos — AWS S3 (opcional, credenciales DIFERENTES) ──
# IAM user separado con permisos minimos (solo PutObject + GetObject).
# Deja vacios si no usas respaldos a la nube.
S3_BACKUP_ACCESS_KEY_ID=
S3_BACKUP_SECRET_ACCESS_KEY=
S3_BACKUP_BUCKET=historial-pediatrico-backups
S3_BACKUP_PREFIX=miriam-01
S3_BACKUP_REGION=us-east-1
